APP_NAME=Neural Knowledge Engine
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000
API_PREFIX=
LOG_LEVEL=INFO
LOG_JSON_FORMAT=true
METRICS_ENABLED=true

OPENAI_API_KEY=your-openai-api-key
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.0
OPENAI_REQUEST_TIMEOUT=60
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF_SECONDS=1.0

DOCUMENTS_DIRECTORY=data/documents
CHROMA_PERSIST_DIRECTORY=data/chroma
CHROMA_COLLECTION_NAME=neural_knowledge_documents
RETRIEVAL_K=5
CHUNK_SIZE_TOKENS=800
CHUNK_OVERLAP_TOKENS=120
CONTEXT_MAX_DOCUMENTS=6
CONTEXT_MAX_CHARACTERS=6000
HYBRID_VECTOR_WEIGHT=0.65
HYBRID_KEYWORD_WEIGHT=0.35

REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=3600

DATABASE_URL=postgresql+psycopg://neural:neural@postgres:5432/neural_knowledge_engine

CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2